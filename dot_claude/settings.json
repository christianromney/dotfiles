{
  "cleanupPeriodDays": 99999,
  "env": {
    "ENABLE_LSP_TOOL": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read(~/dev/nu/**)",
      "Edit(~/dev/nu/**)",
      "Write(~/dev/nu/**)",
      "Glob(~/dev/nu/**)",
      "Grep(~/dev/nu/**)",
      "Read(~/src/**)",
      "Edit(~/src/**)",
      "Write(~/src/**)",
      "Glob(~/src/**)",
      "Grep(~/src/**)",
      "Read(~/Documents/personal/notes/**)",
      "Edit(~/Documents/personal/notes/**)",
      "Write(~/Documents/personal/notes/**)",
      "Glob(~/Documents/personal/notes/**)",
      "Grep(~/Documents/personal/notes/**)",
      "WebSearch",
      "WebFetch",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(jj:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(man:*)",
      "Bash(nu:*)",
      "Bash(pbcopy:*)",
      "Bash(pgrep:*)",
      "Bash(ps:*)",
      "Bash(psgrep:*)",
      "Bash(stat:*)",
      "Bash(test:*)",
      "mcp__clojure__read_file",
      "mcp__clojure__grep",
      "mcp__clojure__glob_files",
      "mcp__clojure__scratch_pad",
      "mcp__clojure__clojure_inspect_project",
      "mcp__clojure__list_nrepl_ports",
      "mcp__clojure__dispatch_agent",
      "mcp__clojure__architect",
      "mcp__clojure__code_critique",
      "mcp__clojure__clojure_eval",
      "mcp__clojure__bash",
      "mcp__clojure__clojure_edit",
      "mcp__clojure__clojure_edit_replace_sexp",
      "mcp__clojure__clojure_edit_agent",
      "mcp__clojure__file_edit",
      "mcp__clojure__file_write",
      "mcp__glean_default_*",
      "mcp__plugin_slack_slack__*",
      "mcp__basic-memory__*",
      "mcp__google-workspace__*",
      "mcp__plugin_atlassian_atlassian__*",
      "Bash",
      "Skill(slack:*)",
      "Skill(usage-insights:usage-insights)",
      "Write(~/.claude/usage-insights/**)",
      "Read(~/.claude/usage-insights/**)"
    ],
    "additionalDirectories": [
      "~/.claude/usage-insights"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/credential-guard.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/statusline-command.py"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "mintlify@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "usage-insights@christianromney-claude-plugins": true,
    "journal@christianromney-claude-plugins": true,
    "chezmoi@christianromney-claude-plugins": true,
    "jujutsu@christianromney-claude-plugins": true,
    "sync@christianromney-claude-plugins": true,
    "socratic-partner@christianromney-claude-plugins": true,
    "frontend-design@claude-plugins-official": true,
    "generate@christianromney-claude-plugins": true,
    "session-advisor@nubank-ai-agents-plugins": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "nubank-ai-agents-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/nubank/ai-agents-plugins.git"
      },
      "autoUpdate": true
    },
    "christianromney-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "christianromney/claude-plugins"
      },
      "autoUpdate": true
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Teeing off",
      "Taking a divot",
      "Visualizing the shot",
      "Playing the wind",
      "Repairing a ball mark",
      "Tucking the hips",
      "Putting for birdie",
      "Bumping and running",
      "Reading the green",
      "Assessing the lie",
      "Picking a target",
      "Making a backswing",
      "Following through",
      "Marking the ball",
      "Taking a drop",
      "Hitting a provisional",
      "Escaping the bunker",
      "Cleaning the grooves",
      "Holding the finish"
    ]
  },
  "alwaysThinkingEnabled": true,
  "advisorModel": "opus",
  "showClearContextOnPlanAccept": true,
  "theme": "light",
  "preferredNotifChannel": "ghostty"
}
