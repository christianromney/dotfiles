{
  "env": {
    "ENABLE_LSP_TOOL": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read(~/dev/nu/**)",
      "Edit(~/dev/nu/**)",
      "Write(~/dev/nu/**)",
      "Glob(~/dev/nu/**)",
      "Grep(~/dev/nu/**)",
      "Read(~/src/**)",
      "Edit(~/src/**)",
      "Write(~/src/**)",
      "Glob(~/src/**)",
      "Grep(~/src/**)",
      "Read(~/Documents/personal/notes/**)",
      "Edit(~/Documents/personal/notes/**)",
      "Write(~/Documents/personal/notes/**)",
      "Glob(~/Documents/personal/notes/**)",
      "Grep(~/Documents/personal/notes/**)",
      "WebSearch",
      "WebFetch",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(jj:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(man:*)",
      "Bash(nu:*)",
      "Bash(pbcopy:*)",
      "Bash(pgrep:*)",
      "Bash(ps:*)",
      "Bash(psgrep:*)",
      "Bash(stat:*)",
      "Bash(test:*)",
      "mcp__clojure__read_file",
      "mcp__clojure__grep",
      "mcp__clojure__glob_files",
      "mcp__clojure__scratch_pad",
      "mcp__clojure__clojure_inspect_project",
      "mcp__clojure__list_nrepl_ports",
      "mcp__clojure__dispatch_agent",
      "mcp__clojure__architect",
      "mcp__clojure__code_critique",
      "mcp__clojure__clojure_eval",
      "mcp__clojure__bash",
      "mcp__clojure__clojure_edit",
      "mcp__clojure__clojure_edit_replace_sexp",
      "mcp__clojure__clojure_edit_agent",
      "mcp__clojure__file_edit",
      "mcp__clojure__file_write",
      "mcp__glean_default__search",
      "mcp__glean_default__chat",
      "mcp__glean_default__read_document",
      "mcp__slack__channels_list",
      "mcp__slack__conversations_history",
      "mcp__slack__conversations_replies",
      "mcp__slack__conversations_search_messages",
      "mcp__basic-memory__*",
      "mcp__google-workspace__docs_getText",
      "mcp__google-workspace__docs_find",
      "mcp__google-workspace__docs_create",
      "mcp__google-workspace__docs_appendText",
      "mcp__google-workspace__docs_replaceText",
      "mcp__google-workspace__docs_insertText",
      "mcp__google-workspace__docs_move",
      "mcp__google-workspace__docs_extractIdFromUrl",
      "mcp__google-workspace__sheets_getText",
      "mcp__google-workspace__sheets_getMetadata",
      "mcp__google-workspace__sheets_find",
      "mcp__google-workspace__sheets_getRange",
      "mcp__google-workspace__slides_getText",
      "mcp__google-workspace__slides_find",
      "mcp__google-workspace__slides_getMetadata",
      "mcp__google-workspace__gmail_search",
      "mcp__google-workspace__gmail_get",
      "mcp__google-workspace__gmail_send",
      "mcp__google-workspace__gmail_createDraft",
      "mcp__google-workspace__gmail_sendDraft",
      "mcp__google-workspace__gmail_modify",
      "mcp__google-workspace__gmail_listLabels",
      "mcp__google-workspace__gmail_downloadAttachment",
      "mcp__google-workspace__chat_listSpaces",
      "mcp__google-workspace__chat_getMessages",
      "mcp__google-workspace__chat_findSpaceByName",
      "mcp__google-workspace__chat_findDmByEmail",
      "mcp__google-workspace__chat_listThreads",
      "mcp__google-workspace__chat_sendMessage",
      "mcp__google-workspace__chat_sendDm",
      "mcp__google-workspace__chat_setUpSpace",
      "mcp__google-workspace__calendar_list",
      "mcp__google-workspace__calendar_listEvents",
      "mcp__google-workspace__calendar_getEvent",
      "mcp__google-workspace__calendar_findFreeTime",
      "mcp__google-workspace__calendar_createEvent",
      "mcp__google-workspace__calendar_updateEvent",
      "mcp__google-workspace__calendar_respondToEvent",
      "mcp__google-workspace__calendar_deleteEvent",
      "mcp__google-workspace__people_getMe",
      "mcp__google-workspace__people_getUserProfile",
      "mcp__google-workspace__people_getUserRelations",
      "mcp__google-workspace__time_getCurrentDate",
      "mcp__google-workspace__time_getCurrentTime",
      "mcp__google-workspace__time_getTimeZone",
      "mcp__google-workspace__drive_search",
      "mcp__google-workspace__drive_findFolder",
      "mcp__google-workspace__drive_createFolder",
      "mcp__google-workspace__drive_downloadFile",
      "mcp__plugin_atlassian_atlassian__*",
      "Bash",
      "Skill(usage-insights:usage-insights)",
      "Write(~/.claude/usage-insights/**)",
      "Read(~/.claude/usage-insights/**)"
    ],
    "additionalDirectories": [
      "~/.claude/usage-insights"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/chezmoi-re-add-claude-dir",
            "statusMessage": "Syncing to chezmoi..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/credential-guard.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.clj"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "mintlify@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "usage-insights@christianromney-claude-plugins": true,
    "journal@christianromney-claude-plugins": true,
    "generate@christianromney-claude-plugins": true,
    "chezmoi@christianromney-claude-plugins": true,
    "jujutsu@christianromney-claude-plugins": true,
    "sync@christianromney-claude-plugins": true,
    "socratic-partner@christianromney-claude-plugins": true,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "nubank-ai-agents-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/nubank/ai-agents-plugins.git"
      },
      "autoUpdate": true
    },
    "christianromney-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "christianromney/claude-plugins"
      },
      "autoUpdate": true
    }
  },
  "alwaysThinkingEnabled": true,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Teeing off",
      "Taking a divot",
      "Visualizing the shot",
      "Playing the wind",
      "Repairing a ball mark",
      "Tucking the hips",
      "Putting for birdie",
      "Bumping and running",
      "Reading the green",
      "Assessing the lie",
      "Picking a target",
      "Making a backswing",
      "Following through",      
      "Marking the ball",
      "Taking a drop",
      "Hitting a provisional",
      "Escaping the bunker",
      "Cleaning the grooves",
      "Holding the finish"
    ]
  }
}
